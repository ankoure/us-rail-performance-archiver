# data
archive/
curated/
static_gtfs/  # ~300MB runtime GTFS-zip cache; gold.py downloads on demand
*.parquet
*.jsonl
*.bin

# python
.venv/
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/

# vcs / ci
.git/
.github/

# secrets / local
.env
# config/feeds.yaml IS baked in (no secrets — only env-var names; agency keys come
# from Secrets Manager / .env at runtime) so the Fargate rollup task, which has no
# volume mount, can read it. The poller still mounts ./config over the baked copy.
# Keep the large local-only candidate lists out of the image.
config/feeds.candidates*.yaml