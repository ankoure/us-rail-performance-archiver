{
  "title": "Rail Archiver — Pipeline Health",
  "description": "Polling, rollup, and shipping for GTFS-RT feeds. Imported from dashboards/rail-archiver.json.",
  "layout_type": "ordered",
  "reflow_type": "auto",
  "template_variables": [
    {
      "name": "env",
      "prefix": "env",
      "available_values": [],
      "default": "prod"
    },
    {
      "name": "feed",
      "prefix": "feed",
      "available_values": [],
      "default": "*"
    },
    {
      "name": "agency",
      "prefix": "agency",
      "available_values": [],
      "default": "*"
    }
  ],
  "widgets": [
    {
      "definition": {
        "type": "group",
        "layout_type": "ordered",
        "title": "Pipeline health (glance)",
        "widgets": [
          {
            "definition": {
              "type": "query_value",
              "title": "Successful polls / min",
              "precision": 1,
              "autoscale": true,
              "requests": [
                {
                  "response_format": "scalar",
                  "queries": [
                    {
                      "name": "polls_ok",
                      "data_source": "metrics",
                      "query": "sum:feed.poll.duration.count{$env, service:rail-archiver, status:ok, $feed}.as_rate()",
                      "aggregator": "avg"
                    }
                  ],
                  "formulas": [{ "formula": "polls_ok * 60" }]
                }
              ]
            }
          },
          {
            "definition": {
              "type": "query_value",
              "title": "Poll error rate (%)",
              "precision": 2,
              "autoscale": false,
              "custom_unit": "%",
              "requests": [
                {
                  "response_format": "scalar",
                  "queries": [
                    {
                      "name": "errors",
                      "data_source": "metrics",
                      "query": "sum:feed.poll.duration.count{$env, service:rail-archiver, status:error, $feed}.as_count()",
                      "aggregator": "sum"
                    },
                    {
                      "name": "total",
                      "data_source": "metrics",
                      "query": "sum:feed.poll.duration.count{$env, service:rail-archiver, $feed}.as_count()",
                      "aggregator": "sum"
                    }
                  ],
                  "formulas": [{ "formula": "(errors / total) * 100" }],
                  "conditional_formats": [
                    {
                      "comparator": "<",
                      "value": 1,
                      "palette": "white_on_green"
                    },
                    {
                      "comparator": "<",
                      "value": 5,
                      "palette": "white_on_yellow"
                    },
                    {
                      "comparator": ">=",
                      "value": 5,
                      "palette": "white_on_red"
                    }
                  ]
                }
              ]
            }
          },
          {
            "definition": {
              "type": "toplist",
              "title": "Quietest feeds (last 15m — investigate any at 0)",
              "requests": [
                {
                  "response_format": "scalar",
                  "queries": [
                    {
                      "name": "by_feed",
                      "data_source": "metrics",
                      "query": "sum:feed.poll.duration.count{$env, service:rail-archiver, $feed} by {feed}.as_count()",
                      "aggregator": "sum"
                    }
                  ],
                  "formulas": [
                    {
                      "formula": "by_feed",
                      "limit": { "count": 10, "order": "asc" }
                    }
                  ]
                }
              ]
            }
          }
        ]
      }
    },
    {
      "definition": {
        "type": "group",
        "layout_type": "ordered",
        "title": "Feed polling",
        "widgets": [
          {
            "definition": {
              "type": "timeseries",
              "title": "Poll latency p95 by feed",
              "show_legend": true,
              "legend_layout": "auto",
              "yaxis": {
                "scale": "linear",
                "include_zero": true,
                "label": "ms"
              },
              "requests": [
                {
                  "response_format": "timeseries",
                  "display_type": "line",
                  "queries": [
                    {
                      "name": "p95",
                      "data_source": "metrics",
                      "query": "avg:feed.poll.duration.95percentile{$env, service:rail-archiver, $feed} by {feed}"
                    }
                  ],
                  "formulas": [{ "formula": "p95" }]
                }
              ]
            }
          },
          {
            "definition": {
              "type": "timeseries",
              "title": "Poll errors by feed and error_type",
              "show_legend": true,
              "legend_layout": "auto",
              "requests": [
                {
                  "response_format": "timeseries",
                  "display_type": "bars",
                  "queries": [
                    {
                      "name": "errs",
                      "data_source": "metrics",
                      "query": "sum:feed.poll.duration.count{$env, service:rail-archiver, status:error, $feed} by {feed,error_type}.as_count()"
                    }
                  ],
                  "formulas": [{ "formula": "errs" }],
                  "style": { "palette": "warm" }
                }
              ]
            }
          }
        ]
      }
    },
    {
      "definition": {
        "type": "group",
        "layout_type": "ordered",
        "title": "Rollup (landing → curated parquet)",
        "widgets": [
          {
            "definition": {
              "type": "timeseries",
              "title": "rollup.day latency p95 by feed",
              "show_legend": true,
              "yaxis": { "label": "ms" },
              "requests": [
                {
                  "response_format": "timeseries",
                  "display_type": "line",
                  "queries": [
                    {
                      "name": "p95",
                      "data_source": "metrics",
                      "query": "avg:rollup.day.duration.95percentile{$env, service:rail-archiver, $feed} by {feed}"
                    }
                  ],
                  "formulas": [{ "formula": "p95" }]
                }
              ]
            }
          },
          {
            "definition": {
              "type": "timeseries",
              "title": "Rollup skipped (idempotency hits) by feed",
              "show_legend": true,
              "requests": [
                {
                  "response_format": "timeseries",
                  "display_type": "bars",
                  "queries": [
                    {
                      "name": "skip",
                      "data_source": "metrics",
                      "query": "sum:rollup.skipped{$env, service:rail-archiver, $feed} by {feed}.as_count()"
                    }
                  ],
                  "formulas": [{ "formula": "skip" }]
                }
              ]
            }
          },
          {
            "definition": {
              "type": "timeseries",
              "title": "rollup.run errors (whole-run wrapper)",
              "show_legend": false,
              "requests": [
                {
                  "response_format": "timeseries",
                  "display_type": "bars",
                  "queries": [
                    {
                      "name": "run_err",
                      "data_source": "metrics",
                      "query": "sum:rollup.run.duration.count{$env, service:rail-archiver, status:error}.as_count()"
                    }
                  ],
                  "formulas": [{ "formula": "run_err" }],
                  "style": { "palette": "warm" }
                }
              ]
            }
          }
        ]
      }
    },
    {
      "definition": {
        "type": "group",
        "layout_type": "ordered",
        "title": "Shipping to S3",
        "widgets": [
          {
            "definition": {
              "type": "timeseries",
              "title": "ship.cold latency p95 by feed",
              "show_legend": true,
              "yaxis": { "label": "ms" },
              "requests": [
                {
                  "response_format": "timeseries",
                  "display_type": "line",
                  "queries": [
                    {
                      "name": "p95",
                      "data_source": "metrics",
                      "query": "avg:ship.cold.duration.95percentile{$env, service:rail-archiver, $feed, $agency} by {feed}"
                    }
                  ],
                  "formulas": [{ "formula": "p95" }]
                }
              ]
            }
          },
          {
            "definition": {
              "type": "timeseries",
              "title": "ship.cold typical tarball size by feed (avg bytes)",
              "show_legend": true,
              "yaxis": { "label": "bytes" },
              "requests": [
                {
                  "response_format": "timeseries",
                  "display_type": "area",
                  "queries": [
                    {
                      "name": "size",
                      "data_source": "metrics",
                      "query": "avg:ship.cold.bytes.avg{$env, service:rail-archiver, $feed, $agency} by {feed}"
                    }
                  ],
                  "formulas": [{ "formula": "size" }]
                }
              ]
            }
          },
          {
            "definition": {
              "type": "timeseries",
              "title": "ship.hot latency p95 by feed & kind",
              "show_legend": true,
              "yaxis": { "label": "ms" },
              "requests": [
                {
                  "response_format": "timeseries",
                  "display_type": "line",
                  "queries": [
                    {
                      "name": "p95",
                      "data_source": "metrics",
                      "query": "avg:ship.hot.duration.95percentile{$env, service:rail-archiver, $feed, $agency} by {feed,kind}"
                    }
                  ],
                  "formulas": [{ "formula": "p95" }]
                }
              ]
            }
          },
          {
            "definition": {
              "type": "timeseries",
              "title": "ship.hot typical parquet size by kind (avg bytes)",
              "show_legend": true,
              "yaxis": { "label": "bytes" },
              "requests": [
                {
                  "response_format": "timeseries",
                  "display_type": "area",
                  "queries": [
                    {
                      "name": "size",
                      "data_source": "metrics",
                      "query": "avg:ship.hot.bytes.avg{$env, service:rail-archiver, $feed, $agency} by {kind}"
                    }
                  ],
                  "formulas": [{ "formula": "size" }]
                }
              ]
            }
          },
          {
            "definition": {
              "type": "timeseries",
              "title": "Skips (already-shipped) — cold vs hot",
              "show_legend": true,
              "requests": [
                {
                  "response_format": "timeseries",
                  "display_type": "bars",
                  "queries": [
                    {
                      "name": "cold",
                      "data_source": "metrics",
                      "query": "sum:ship.cold.skipped{$env, service:rail-archiver, $feed, $agency}.as_count()"
                    },
                    {
                      "name": "hot",
                      "data_source": "metrics",
                      "query": "sum:ship.hot.skipped{$env, service:rail-archiver, $feed, $agency}.as_count()"
                    }
                  ],
                  "formulas": [
                    { "formula": "cold", "alias": "cold (tarballs)" },
                    { "formula": "hot", "alias": "hot (parquet)" }
                  ]
                }
              ]
            }
          }
        ]
      }
    },
    {
      "definition": {
        "type": "group",
        "layout_type": "ordered",
        "title": "S3 cost (estimated)",
        "widgets": [
          {
            "definition": {
              "type": "note",
              "content": "Estimated from our own s3.request counts x us-east-1 list pricing: PUT/LIST $0.005/1k, GET/HEAD $0.0004/1k, DELETE free. Request cost only — storage and (free in-region) transfer not included. LISTs counted per-call, not per-page (sub-cent error).",
              "background_color": "gray",
              "font_size": "14",
              "text_align": "left",
              "show_tick": false
            }
          },
          {
            "definition": {
              "type": "query_value",
              "title": "S3 request cost — last 24h (est. $)",
              "precision": 3,
              "custom_unit": "$",
              "autoscale": false,
              "time": { "live_span": "1d" },
              "requests": [
                {
                  "response_format": "scalar",
                  "queries": [
                    {
                      "name": "put",
                      "data_source": "metrics",
                      "query": "sum:s3.request{$env, service:rail-archiver, op:put}.as_count()",
                      "aggregator": "sum"
                    },
                    {
                      "name": "list",
                      "data_source": "metrics",
                      "query": "sum:s3.request{$env, service:rail-archiver, op:list}.as_count()",
                      "aggregator": "sum"
                    },
                    {
                      "name": "get",
                      "data_source": "metrics",
                      "query": "sum:s3.request{$env, service:rail-archiver, op:get}.as_count()",
                      "aggregator": "sum"
                    },
                    {
                      "name": "head",
                      "data_source": "metrics",
                      "query": "sum:s3.request{$env, service:rail-archiver, op:head}.as_count()",
                      "aggregator": "sum"
                    }
                  ],
                  "formulas": [
                    {
                      "formula": "(put + list) * 0.000005 + (get + head) * 0.0000004"
                    }
                  ]
                }
              ]
            }
          },
          {
            "definition": {
              "type": "query_value",
              "title": "Projected monthly S3 request cost (est. $ = 24h x 30)",
              "precision": 2,
              "custom_unit": "$",
              "autoscale": false,
              "time": { "live_span": "1d" },
              "requests": [
                {
                  "response_format": "scalar",
                  "queries": [
                    {
                      "name": "put",
                      "data_source": "metrics",
                      "query": "sum:s3.request{$env, service:rail-archiver, op:put}.as_count()",
                      "aggregator": "sum"
                    },
                    {
                      "name": "list",
                      "data_source": "metrics",
                      "query": "sum:s3.request{$env, service:rail-archiver, op:list}.as_count()",
                      "aggregator": "sum"
                    },
                    {
                      "name": "get",
                      "data_source": "metrics",
                      "query": "sum:s3.request{$env, service:rail-archiver, op:get}.as_count()",
                      "aggregator": "sum"
                    },
                    {
                      "name": "head",
                      "data_source": "metrics",
                      "query": "sum:s3.request{$env, service:rail-archiver, op:head}.as_count()",
                      "aggregator": "sum"
                    }
                  ],
                  "formulas": [
                    {
                      "formula": "((put + list) * 0.000005 + (get + head) * 0.0000004) * 30"
                    }
                  ]
                }
              ]
            }
          },
          {
            "definition": {
              "type": "timeseries",
              "title": "Estimated S3 request cost per day ($)",
              "show_legend": true,
              "yaxis": { "label": "$", "include_zero": true },
              "requests": [
                {
                  "response_format": "timeseries",
                  "display_type": "bars",
                  "queries": [
                    {
                      "name": "put",
                      "data_source": "metrics",
                      "query": "sum:s3.request{$env, service:rail-archiver, op:put}.as_count().rollup(sum, 86400)"
                    },
                    {
                      "name": "list",
                      "data_source": "metrics",
                      "query": "sum:s3.request{$env, service:rail-archiver, op:list}.as_count().rollup(sum, 86400)"
                    },
                    {
                      "name": "get",
                      "data_source": "metrics",
                      "query": "sum:s3.request{$env, service:rail-archiver, op:get}.as_count().rollup(sum, 86400)"
                    },
                    {
                      "name": "head",
                      "data_source": "metrics",
                      "query": "sum:s3.request{$env, service:rail-archiver, op:head}.as_count().rollup(sum, 86400)"
                    }
                  ],
                  "formulas": [
                    {
                      "formula": "(put + list) * 0.000005 + (get + head) * 0.0000004",
                      "alias": "est. $/day"
                    }
                  ]
                }
              ]
            }
          },
          {
            "definition": {
              "type": "timeseries",
              "title": "S3 requests by op (count)",
              "show_legend": true,
              "requests": [
                {
                  "response_format": "timeseries",
                  "display_type": "bars",
                  "queries": [
                    {
                      "name": "by_op",
                      "data_source": "metrics",
                      "query": "sum:s3.request{$env, service:rail-archiver} by {op}.as_count()"
                    }
                  ],
                  "formulas": [{ "formula": "by_op" }]
                }
              ]
            }
          },
          {
            "definition": {
              "type": "toplist",
              "title": "Cold archive bytes by agency (avg tarball size)",
              "requests": [
                {
                  "response_format": "scalar",
                  "queries": [
                    {
                      "name": "bytes",
                      "data_source": "metrics",
                      "query": "avg:ship.cold.bytes.avg{$env, service:rail-archiver} by {agency}",
                      "aggregator": "avg"
                    }
                  ],
                  "formulas": [
                    {
                      "formula": "bytes",
                      "limit": { "count": 20, "order": "desc" }
                    }
                  ]
                }
              ]
            }
          },
          {
            "definition": {
              "type": "toplist",
              "title": "Hot parquet bytes by agency (sum per day)",
              "requests": [
                {
                  "response_format": "scalar",
                  "queries": [
                    {
                      "name": "bytes",
                      "data_source": "metrics",
                      "query": "sum:ship.hot.bytes.sum{$env, service:rail-archiver} by {agency}.rollup(sum, 86400)",
                      "aggregator": "sum"
                    }
                  ],
                  "formulas": [
                    {
                      "formula": "bytes",
                      "limit": { "count": 20, "order": "desc" }
                    }
                  ]
                }
              ]
            }
          },
          {
            "definition": {
              "type": "timeseries",
              "title": "Est. S3 request cost by bucket ($/day)",
              "show_legend": true,
              "yaxis": { "label": "$" },
              "requests": [
                {
                  "response_format": "timeseries",
                  "display_type": "bars",
                  "queries": [
                    {
                      "name": "put",
                      "data_source": "metrics",
                      "query": "sum:s3.request{$env, service:rail-archiver, op:put} by {bucket}.as_count().rollup(sum, 86400)"
                    },
                    {
                      "name": "list",
                      "data_source": "metrics",
                      "query": "sum:s3.request{$env, service:rail-archiver, op:list} by {bucket}.as_count().rollup(sum, 86400)"
                    },
                    {
                      "name": "get",
                      "data_source": "metrics",
                      "query": "sum:s3.request{$env, service:rail-archiver, op:get} by {bucket}.as_count().rollup(sum, 86400)"
                    },
                    {
                      "name": "head",
                      "data_source": "metrics",
                      "query": "sum:s3.request{$env, service:rail-archiver, op:head} by {bucket}.as_count().rollup(sum, 86400)"
                    }
                  ],
                  "formulas": [
                    {
                      "formula": "(put + list) * 0.000005 + (get + head) * 0.0000004"
                    }
                  ]
                }
              ]
            }
          }
        ]
      }
    }
  ]
}
